digraph RAASAControlLoop {
  graph [
    rankdir=LR,
    fontname="Helvetica",
    fontsize=18,
    labelloc=t,
    label="RAASA Control Loop with Privilege Separation",
    splines=ortho,
    nodesep=0.45,
    ranksep=0.7,
    pad=0.2
  ];

  node [
    shape=box,
    style="rounded,filled",
    fontname="Helvetica",
    fontsize=11,
    color="#334155",
    fillcolor="#F8FAFC",
    margin="0.10,0.06"
  ];

  edge [
    color="#475569",
    penwidth=1.4,
    arrowsize=0.8,
    fontname="Helvetica",
    fontsize=10
  ];

  workloads [
    label="Containerized workloads\nbenign, suspicious, malicious",
    fillcolor="#EFF6FF",
    color="#2563EB"
  ];

  signals [
    label="Runtime telemetry\nCPU, memory, process, network, syscall",
    fillcolor="#ECFDF5",
    color="#059669"
  ];

  subgraph cluster_controller {
    label="Unprivileged Controller Plane";
    color="#CBD5E1";
    style="rounded,dashed";
    penwidth=1.3;

    observe [label="Observe\ncollect and normalize signals", fillcolor="#F8FAFC"];
    assess [label="Assess\nbounded features and risk scoring", fillcolor="#F8FAFC"];
    decide [label="Decide\ntier selection L1 / L2 / L3", fillcolor="#F8FAFC"];
    audit [label="Audit\nreason strings and decision rows", fillcolor="#FFF7ED", color="#EA580C"];
  }

  ipc [
    label="Constrained IPC command\nsmall, explicit enforcement request",
    fillcolor="#FEF3C7",
    color="#D97706"
  ];

  subgraph cluster_enforcer {
    label="Privileged Enforcement Plane";
    color="#CBD5E1";
    style="rounded,dashed";
    penwidth=1.3;

    enforcer [label="Enforcer sidecar\napply cgroup / tc actions", fillcolor="#FEE2E2", color="#DC2626"];
    tiers [label="Containment effect\nL1 open / L2 degraded / L3 hard containment", fillcolor="#F8FAFC"];
  }

  logs [
    label="Evidence artifacts\nJSONL rows, summaries, tails, probes",
    fillcolor="#F5F3FF",
    color="#7C3AED"
  ];

  workloads -> signals [label="behavior"];
  signals -> observe;
  observe -> assess;
  assess -> decide;
  decide -> ipc;
  ipc -> enforcer;
  enforcer -> tiers;
  tiers -> workloads [label="runtime effect"];
  decide -> audit;
  observe -> audit;
  enforcer -> audit;
  audit -> logs;
}
